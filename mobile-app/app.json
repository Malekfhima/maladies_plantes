{
  "expo": {
    "name": "Plant Disease Detection",
    "slug": "plant-disease-detection",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#4CAF50"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.plantdisease.app",
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs camera access to capture plant images for disease detection.",
        "NSPhotoLibraryUsageDescription": "This app needs photo library access to select plant images for disease detection.",
        "NSPhotoLibraryAddUsageDescription": "This app needs permission to save analyzed images to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4CAF50"
      },
      "package": "com.plantdisease.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-camera",
      "expo-image-picker",
      "expo-media-library"
    ]
  }
}
